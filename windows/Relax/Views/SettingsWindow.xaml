<Window x:Class="Relax.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Relax 設定" Width="440" Height="560"
        WindowStartupLocation="CenterScreen" ResizeMode="CanMinimize">
    <StackPanel Margin="16">

        <TextBlock Text="蕃茄鐘" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="工作（分鐘）" Width="90" VerticalAlignment="Center"/>
            <TextBox x:Name="WorkBox" Width="60" PreviewTextInput="IntegerOnly"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="休息（分鐘）" Width="90" VerticalAlignment="Center"/>
            <TextBox x:Name="BreakBox" Width="60" PreviewTextInput="IntegerOnly"/>
        </StackPanel>

        <TextBlock Text="指定時間鬧鐘" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
        <ListBox x:Name="AlarmList" Height="170" Margin="0,0,0,8">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding Enabled, Mode=OneWay}"
                                  Checked="AlarmEnabledChanged" Unchecked="AlarmEnabledChanged"
                                  Tag="{Binding Id}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TimeString}" FontWeight="Bold" Width="56"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Label}" Foreground="Gray" Width="160"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button Content="刪除" Tag="{Binding Id}" Click="DeleteAlarm" Padding="8,2"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
            <ComboBox x:Name="HourBox" Width="58"/>
            <TextBlock Text=":" VerticalAlignment="Center" Margin="4,0"/>
            <ComboBox x:Name="MinuteBox" Width="58"/>
            <TextBox x:Name="LabelBox" Width="140" Margin="8,0" VerticalContentAlignment="Center"/>
            <Button Content="新增" Click="AddAlarm" Padding="12,2"/>
        </StackPanel>

        <TextBlock Text="其他" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
        <CheckBox x:Name="SoundBox" Content="啟用音效" Margin="0,0,0,8"
                  Checked="SoundChanged" Unchecked="SoundChanged"/>
        <Button Content="試聽音效" Click="TestSound" HorizontalAlignment="Left"
                Padding="12,2" Margin="0,0,0,12"/>
        <CheckBox x:Name="StartupBox" Content="開機自動啟動"
                  Checked="StartupChanged" Unchecked="StartupChanged"/>

    </StackPanel>
</Window>
